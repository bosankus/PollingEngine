root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 140
# The published Maven group is `in.androidplay`; `in` is a Kotlin keyword that
# ktlint's standard package-name rule rejects, so disable that rule.
ktlint_standard_package-name = disabled
